# MATLAB output directories (regenerated by running the batch scripts).
# Shipped sample data (*_sample.mat) is kept; all other matfile/ contents are ignored.
matfile/*
!matfile/*_sample.mat
photo/
csv/
json/
diag/

# MATLAB editor / autosave artifacts
*.asv
*.m~
slprj/

# OS / editor cruft
.DS_Store
Thumbs.db
*.swp
